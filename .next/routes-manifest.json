{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/foh/orders/[id]/status",
      "regex": "^/api/foh/orders/([^/]+?)/status(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/foh/orders/(?<nxtPid>[^/]+?)/status(?:/)?$"
    },
    {
      "page": "/api/orders/[shortCode]",
      "regex": "^/api/orders/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPshortCode": "nxtPshortCode"
      },
      "namedRegex": "^/api/orders/(?<nxtPshortCode>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/venues/[slug]",
      "regex": "^/api/venues/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/venues/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/d/[venueSlug]",
      "regex": "^/d/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPvenueSlug": "nxtPvenueSlug"
      },
      "namedRegex": "^/d/(?<nxtPvenueSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/d/[venueSlug]/order",
      "regex": "^/d/([^/]+?)/order(?:/)?$",
      "routeKeys": {
        "nxtPvenueSlug": "nxtPvenueSlug"
      },
      "namedRegex": "^/d/(?<nxtPvenueSlug>[^/]+?)/order(?:/)?$"
    },
    {
      "page": "/foh/[venueSlug]",
      "regex": "^/foh/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPvenueSlug": "nxtPvenueSlug"
      },
      "namedRegex": "^/foh/(?<nxtPvenueSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/o/[shortCode]",
      "regex": "^/o/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPshortCode": "nxtPshortCode"
      },
      "namedRegex": "^/o/(?<nxtPshortCode>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/dev/checkout-probe",
      "regex": "^/dev/checkout\\-probe(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dev/checkout\\-probe(?:/)?$"
    },
    {
      "page": "/dev/payments/health",
      "regex": "^/dev/payments/health(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dev/payments/health(?:/)?$"
    },
    {
      "page": "/dev-launch",
      "regex": "^/dev\\-launch(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dev\\-launch(?:/)?$"
    },
    {
      "page": "/dev-launch/login",
      "regex": "^/dev\\-launch/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dev\\-launch/login(?:/)?$"
    },
    {
      "page": "/order-status",
      "regex": "^/order\\-status(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/order\\-status(?:/)?$"
    },
    {
      "page": "/scan-again",
      "regex": "^/scan\\-again(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/scan\\-again(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/test-deeplinks",
      "regex": "^/test\\-deeplinks(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/test\\-deeplinks(?:/)?$"
    },
    {
      "page": "/test-links",
      "regex": "^/test\\-links(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/test\\-links(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}